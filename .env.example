DATABASE_URL="file:./prisma/dev.db"
APP_PASSCODE="change-me"
AUTH_SECRET="generate-a-long-random-string"

# Every "today" in the app (streaks, due dates, check-ins) is computed in
# this IANA timezone rather than the server's own. Must be set at build
# time (it's inlined into the client bundle), so a change on Vercel needs
# a redeploy to take effect.
NEXT_PUBLIC_TIMEZONE="Africa/Nairobi"

# Production only (e.g. Vercel) — a remote Turso database.
# DATABASE_URL="libsql://<db-name>-<org>.turso.io"
# DATABASE_AUTH_TOKEN="<token from the Turso dashboard>"
